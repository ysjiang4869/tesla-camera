{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "pnpm run build:tauri",
    "beforeDevCommand": "pnpm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:6680"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [
      "icons/*"
    ],
    "shortDescription": "",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "createUpdaterArtifacts": "v1Compatible"
  },
  "productName": "TeslaCamera",
  "mainBinaryName": "TeslaCamera",
  "version": "../package.json",
  "identifier": "mario34.top",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJEMEY2QkJCQ0FBQTZBRjIKUldUeWFxckt1MnNQTFhEN3RJbGliOW56U3JRMmlqRWUzQm1qUVZzYzczTWdxMmFKMFN3T0NNWWkK",
      "windows": {
        "installMode": "passive"
      },
      "endpoints": [
        "https://raw.githubusercontent.com/Mario34/gist/main/tesla-camera-update.json",
        "https://gitee.com/mario34/tesla-camera/releases/download/v1-release-external/tesla-camera-update.json"
      ]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "title": "TeslaCamera",
        "useHttpsScheme": true
      }
    ],
    "security": {
      "assetProtocol": {
        "scope": [
          "**"
        ],
        "enable": true
      },
      "csp": null
    }
  }
}